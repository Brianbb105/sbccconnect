  "notes": [
    {
      "id": "38c36f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 0,
      "content": "IMPORTANT MAJOR INFORMATION",
      "contentHtml": null
    },
    {
      "id": "3fc36f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 1,
      "content": "The mission of the Chicana and Chicano Studies major is to train a new generation of scholars to research and analyze the life, history, and culture of Mexican-origin people within the U.S., as well as of other Latina/Latino and indigenous populations in the Americas. Addressing local, national, and transnational contexts, the Chicana/Chicano and Central American Studies curriculum at UCLA explores race, class, gender, and sexuality paradigms as they have shaped the history of the field, as well as new directions in the study of Chicanas/Chicanos and Latinas/Latinos, including (1) border and transnational studies, (2) expressive arts, (3) history, literature, and language of Americas, and (4) labor, law, and policy studies. Listed below are the lower division preparation courses for the major. To be considered for this major, you must complete the following courses by the end of spring before transfer: One year of college level Spanish OR At least one year of high school in which the primary language of instruction was Spanish. Completion of one Chicana/Chicano history and culture course and one Chicana/Chicano social structure and contemporary conditions course are STRONGLY RECOMMENDED . Completion of two years of college level Spanish is STRONGLY RECOMMENDED . All courses must be taken for a letter grade. For more information regarding this major and UCLA's transfer selection process, visit https://chavez.ucla.edu and https://admission.ucla.edu . PLEASE NOTE: the community college courses listed below have approved to satisfy the preparation requirements for this major at UCLA, but they may not be exact equivalents of the UCLA courses listed.",
      "contentHtml": "<p><span style=\"color: rgb(29, 32, 36);\">The mission of the Chicana and Chicano Studies major is to train a new generation of scholars to research and analyze the life, history, and culture of Mexican-origin people within the U.S., as well as of other Latina/Latino and indigenous populations in the Americas. Addressing local, national, and transnational contexts, the Chicana/Chicano and Central American Studies curriculum at UCLA explores race, class, gender, and sexuality paradigms as they have shaped the history of the field, as well as new directions in the study of Chicanas/Chicanos and Latinas/Latinos, including (1) border and transnational studies, (2) expressive arts, (3) history, literature, and language of Americas, and (4) labor, law, and policy studies.</span></p><p><br></p><p>Listed below are the lower division preparation courses for the major.</p><p><br></p><p>To be considered for this major, you must complete the following courses by the end of spring before transfer:</p><ul><li>One year of college level Spanish OR</li><li>At least one year of high school in which the primary language of instruction was Spanish.</li><li>Completion of one Chicana/Chicano history and culture course and one Chicana/Chicano social structure and contemporary conditions course are <strong>STRONGLY RECOMMENDED</strong>.</li></ul><p>Completion of two years of college level Spanish is <strong>STRONGLY RECOMMENDED</strong>.</p><p>All courses must be taken for a letter grade.</p><p><br></p><p>For more information regarding this major and UCLA's transfer selection process, visit <u style=\"color: rgb(41, 98, 255);\">https://chavez.ucla.edu</u> and <u style=\"color: rgb(41, 98, 255);\">https://admission.ucla.edu</u>.</p><p><br></p><p>PLEASE NOTE: the community college courses listed below have approved to satisfy the preparation requirements for this major at UCLA, but they may not be exact equivalents of the UCLA courses listed.</p>"
    },
    {
      "id": "8b539fe6-033f-43af-9ce0-019b9419e716",
      "type": "GeneralTitle",
      "area": "General",
      "position": 2,
      "content": "AP EXAM CREDIT",
      "contentHtml": null
    },
    {
      "id": "d83f23a7-5aa4-4bff-96ec-019b9419e716",
      "type": "GeneralText",
      "area": "General",
      "position": 3,
      "content": "The AP Exam Scores listed below may be used to satisfy the major prep: A score of 3 on AP Spanish Language and Cultures exam is equivalent to SPAN 3. A score of 4 on AP Spanish Language and Cultures exam is equivalent to SPAN 4. A score of 5 on AP Spanish Language and Cultures exam is equivalent to SPAN 5 and can be used in place of this Spanish course.",
      "contentHtml": "<p>The AP Exam Scores listed below may be used to satisfy the major prep:</p><ul><li>A score of <strong><u>3 on AP Spanish Language and Cultures exam</u></strong> is equivalent to SPAN 3.</li><li>A score of <strong><u>4 on AP Spanish Language and Cultures exam</u></strong> is equivalent to SPAN 4. </li><li>A score of <strong><u>5 on AP Spanish Language and Cultures exam</u></strong> is equivalent to SPAN 5 and can be used in place of this Spanish course.</li></ul>"
    }
