  "notes": [
    {
      "id": "ccc26f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 0,
      "content": "IMPORTANT MAJOR INFORMATION",
      "contentHtml": null
    },
    {
      "id": "cbc26f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 1,
      "content": "The goal of linguistics is the enrichment of knowledge about the nature, grammar, and history of human language. Linguistics is a theoretical discipline, akin to philosophy, anthropology, and cognitive psychology. Linguistics courses draw examples from the grammars of a wide variety of languages, and the more languages linguists know about in depth (as distinct from possessing fluency in the use of them), the more likely they are to discover universal properties. Listed below are the lower division preparation courses for the major. To be considered for this major, you must complete the following courses by the end of spring before transfer: One year of college level coursework in the declared language OR At least one year of high school in which the primary language of instruction was the declared language. Completion of introduction to linguistics, and two courses from introduction to linguistic anthropology, introduction to psychology and introduction to logic are STRONGLY RECOMMENDED . Completion of two years of college level foreign language is STRONGLY RECOMMENDED . A placement exam for a language offered at UCLA may be taken upon transfer to test out of or make progress toward the major language requirement. All courses must be taken for a letter grade. For more information regarding this major and UCLA's transfer selection process, visit https:// linguistics.ucla.edu and https:// admission.ucla.edu . PLEASE NOTE: the community college courses listed below have been approved to satisfy the preparation for this major at UCLA, but they may not be exact equivalents of the UCLA courses.",
      "contentHtml": "<p>The goal of linguistics is the enrichment of knowledge about the nature, grammar, and history of human language. Linguistics is a theoretical discipline, akin to philosophy, anthropology, and cognitive psychology. Linguistics courses draw examples from the grammars of a wide variety of languages, and the more languages linguists know about in depth (as distinct from possessing fluency in the use of them), the more likely they are to discover universal properties.</p><p><br></p><p>Listed below are the lower division preparation courses for the major.</p><p><br></p><p>To be considered for this major, you must complete the following courses by the end of spring before transfer:</p><ul><li>One year of college level coursework in the declared language OR</li><li>At least one year of high school in which the primary language of instruction was the declared language.</li></ul><p>Completion of introduction to linguistics, and two courses from introduction to linguistic anthropology, introduction to psychology and introduction to logic are <strong>STRONGLY RECOMMENDED</strong>.</p><p>Completion of two years of college level foreign language is <strong>STRONGLY RECOMMENDED</strong>.</p><p>A placement exam for a language offered at UCLA may be taken upon transfer to test out of or make progress toward the major language requirement.</p><p>All courses must be taken for a letter grade.</p><p><br></p><p>For more information regarding this major and UCLA's transfer selection process, visit <u style=\"color: rgb(41, 98, 255);\">https://</u><a href=\"https://www.linguistics.ucla.edu\" rel=\"noopener noreferrer\" target=\"_blank\">linguistics.ucla.edu</a> and <u style=\"color: rgb(41, 98, 255);\">https://</u><a href=\"http://www.admission.ucla.edu\" rel=\"noopener noreferrer\" target=\"_blank\">admission.ucla.edu</a>.</p><p><br></p><p>PLEASE NOTE: the community college courses listed below have been approved to satisfy the preparation for this major at UCLA, but they may not be exact equivalents of the UCLA courses.</p>"
    },
    {
      "id": "1626f15b-8df4-4d13-8cd9-019b946199ed",
      "type": "GeneralTitle",
      "area": "General",
      "position": 2,
      "content": "AP/IB EXAM CREDIT",
      "contentHtml": null
    },
    {
      "id": "52bcfee2-1e49-4978-89e9-019b946199ed",
      "type": "GeneralText",
      "area": "General",
      "position": 3,
      "content": "The AP Exam Scores listed below may be used to satisfy the major prep: A score of 4 or higher on the AP Psychology exam is equivalent to Psychology 10 and can be used in place of the psychology course. The IB Exam Scores listed below may be used to satisfy the major prep: A score of 5 or higher on the IB HL Psychology exam can be used in place of the psychology course.",
      "contentHtml": "<p>The AP Exam Scores listed below may be used to satisfy the major prep:</p><ul><li>A score of <strong><u>4 or higher on the AP Psychology exam</u></strong> is equivalent to Psychology 10 and can be used in place of the psychology course.</li></ul><p><br></p><p>The IB Exam Scores listed below may be used to satisfy the major prep:</p><ul><li>A score of <strong><u>5 or higher on the IB HL Psychology exam</u></strong> can be used in place of the psychology course.</li></ul>"
    }
