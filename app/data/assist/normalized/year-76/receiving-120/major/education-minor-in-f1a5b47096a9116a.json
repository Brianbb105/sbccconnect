    {
      "id": "48d86f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 1,
      "content": "The minor in Education is designed to facilitate exploration of a broad range of issues in the field of education. Graduates with the Education minor may be employed in schools, government, private industry, and non-profit organizations. Many graduates will pursue advanced training leading to teaching careers or administrative leadership. NOTE : In fulfillment of the requirements below, a single course may be used only once. For information regarding the AP and IB examination credit policies refer to the UCI General Catalogue.",
      "contentHtml": "<p><span style=\"; ; font-size: 14px;\">The minor in Education is designed to facilitate exploration of a broad range of issues in the field of education. Graduates with the Education minor may be employed in schools, government, private industry, and non-profit organizations. Many graduates will pursue advanced training leading to teaching careers or administrative leadership.</span></p><p><br></p><p><strong style=\"; ; font-size: 14px;\">NOTE</strong><span style=\"; ; font-size: 14px;\">: In fulfillment of the requirements below, a single course may be used only once.&nbsp;</span></p><p><br></p><p><span style=\"; ; font-size: 14px;\">For information regarding the</span><a href=\"http://catalogue.uci.edu/informationforprospectivestudents/undergraduateadmissions/#advancedplacementandinternationalbaccalaureatecredittext\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"; ; font-size: 14px;\"> </a><a href=\"http://catalogue.uci.edu/informationforprospectivestudents/undergraduateadmissions/#advancedplacementandinternationalbaccalaureatecredittext\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"; ; font-size: 14px;\">AP and IB examination</a><span style=\"; ; font-size: 14px;\"> credit policies refer to the UCI General Catalogue.</span></p>"
    }
