  "notes": [
    {
      "id": "8d756f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 0,
      "content": "GENERAL INFORMATION FOR ALL MINORS",
      "contentHtml": null
    },
    {
      "id": "90c86f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 1,
      "content": "UC Santa Cruz students may complete one or more minors, provided they can finish all required coursework within their maximum enrollment terms and credit limits. Minors are recorded on the official transcript but do not appear on the diploma. Pursuing a minor is optional and should align with a student’s academic interests and career goals. Students do not apply for minors as part of their UC Santa Cruz admission application. Transfer students interested in a minor should reach out to the department that offers it for advising during their first quarter of enrollment.",
      "contentHtml": "<p><span style=\"font-size: 14px;\">UC Santa Cruz students may complete one or more minors, provided they can finish all required coursework within their maximum enrollment terms and credit limits. Minors are recorded on the official transcript but do not appear on the diploma. Pursuing a minor is optional and should align with a student’s academic interests and career goals.</span></p><p><br></p><p><span style=\"font-size: 14px;\">Students do not apply for minors as part of their UC Santa Cruz admission application. Transfer students interested in a minor should reach out to the department that offers it for advising during their first quarter of enrollment.</span></p>"
    },
    {
      "id": "b609b1c5-89ac-4d13-91c3-019a07874087",
      "type": "GeneralTitle",
      "area": "General",
      "position": 2,
      "content": "EXAM CREDIT",
      "contentHtml": null
    },
    {
      "id": "d7996f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 3,
      "content": "Some Advanced Placement (AP), International Baccalaureate Higher Level (IBH), and Advanced Level (A-level) exams satisfy UCSC course requirements. UCSC's exam credit policies may be found on the Degree Progress Unit website .",
      "contentHtml": "<p><span style=\"font-size: 14px;\">Some Advanced Placement (AP), International Baccalaureate Higher Level&nbsp;(IBH), and Advanced Level (A-level) exams satisfy UCSC course requirements. UCSC's exam credit policies may be found on the </span><a href=\"https://degreeprogress.ucsc.edu/transfer-exam-credit/exam-credit/\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"font-size: 14px;\">Degree Progress Unit website</a><span style=\"font-size: 14px;\">.</span></p>"
    },
    {
      "id": "8c756f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 4,
      "content": "BLACK STUDIES MINOR",
      "contentHtml": null
    },
    {
      "id": "8e756f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 5,
      "content": "PREPARATION FOR THE MINOR One lower-division core course: CRES 68: Approaches to Black Studies Please visit the Critical Race &amp; Ethnic Studies website to learn more about this minor. UC Santa Cruz General Catalog: Black Studies Minor Program Statement",
      "contentHtml": "<h2><strong>PREPARATION FOR THE MINOR</strong></h2><p><br></p><p><strong style=\"font-size: 14px;\">One lower-division core course:</strong></p><p><br></p><p><span style=\"font-size: 14px;\">CRES 68: Approaches to Black Studies </span></p><p><br></p><p><br></p><p><span style=\"font-size: 14px;\">Please visit the </span><a href=\"https://cres.ucsc.edu/\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"font-size: 14px;\">Critical Race &amp; Ethnic Studies website</a><span style=\"font-size: 14px;\"> to learn more about this minor.</span></p><p><a href=\"https://catalog.ucsc.edu/en/current/general-catalog/academic-units/humanities-division/critical-race-and-ethnic-studies/black-studies-minor/\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"font-size: 14px;\">UC Santa Cruz General Catalog: Black Studies Minor Program Statement</a></p>"
    }
