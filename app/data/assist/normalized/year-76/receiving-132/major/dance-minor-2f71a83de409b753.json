  "notes": [
    {
      "id": "58756f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 0,
      "content": "GENERAL INFORMATION FOR ALL MINORS",
      "contentHtml": null
    },
    {
      "id": "90c86f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 1,
      "content": "UC Santa Cruz students may complete one or more minors, provided they can finish all required coursework within their maximum enrollment terms and credit limits. Minors are recorded on the official transcript but do not appear on the diploma. Pursuing a minor is optional and should align with a student’s academic interests and career goals. Students do not apply for minors as part of their UC Santa Cruz admission application. Transfer students interested in a minor should reach out to the department that offers it for advising during their first quarter of enrollment.",
      "contentHtml": "<p><span style=\"font-size: 14px;\">UC Santa Cruz students may complete one or more minors, provided they can finish all required coursework within their maximum enrollment terms and credit limits. Minors are recorded on the official transcript but do not appear on the diploma. Pursuing a minor is optional and should align with a student’s academic interests and career goals.</span></p><p><br></p><p><span style=\"font-size: 14px;\">Students do not apply for minors as part of their UC Santa Cruz admission application. Transfer students interested in a minor should reach out to the department that offers it for advising during their first quarter of enrollment.</span></p>"
    },
    {
      "id": "56756f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 2,
      "content": "DANCE MINOR",
      "contentHtml": null
    },
    {
      "id": "59756f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 3,
      "content": "PREPARATION FOR THE MINOR One of the following courses in creative practice: THEA 30: Introduction to Dance Theory and Technique THEA 36: Introduction to Dance Making Plus one course in cross-cultural techniques, chosen from the following: THEA 31A: Dance Studio I: Asian or Asian Diasporic Practice THEA 31B: Dance Studio I: Ballet THEA 31C: Dance Studio I: Contemporary Dance Theory and Technique THEA 37: African Dance THEA 80R: Bollywood Dance and Culture in India and Indian Diaspora THEA 80U: Everybody Dance Now! THEA 80Z: Indian Dance The following production fundamentals course: THEA 50: Fundamentals of Theater Production Transfer students may petition to have equivalent lower-division courses taken at other schools count toward lower-division minor requirements and should consult with the Theater Arts academic advisor as early as possible regarding this possibility. Please visit the Performance, Play &amp; Design website to learn more about this minor. UC Santa Cruz General Catalog: Dance Minor Program Statement",
      "contentHtml": "<h2><strong>PREPARATION FOR THE MINOR</strong></h2><p><br></p><p><strong style=\"font-size: 14px;\">One of the following courses in creative practice:</strong></p><ul><li><span style=\"font-size: 14px;\">THEA 30: Introduction to Dance Theory and Technique</span></li><li><span style=\"font-size: 14px;\">THEA 36: Introduction to Dance Making</span></li></ul><p><br></p><p><strong style=\"font-size: 14px;\">Plus one course in cross-cultural techniques, chosen from the following:</strong></p><ul><li><span style=\"font-size: 14px;\">THEA 31A: Dance Studio I: Asian or Asian Diasporic Practice</span></li><li><span style=\"font-size: 14px;\">THEA 31B: Dance Studio I: Ballet</span></li><li><span style=\"font-size: 14px;\">THEA 31C: Dance Studio I: Contemporary Dance Theory and Technique</span></li><li><span style=\"font-size: 14px;\">THEA 37: African Dance</span></li><li><span style=\"font-size: 14px;\">THEA 80R: Bollywood Dance and Culture in India and Indian Diaspora</span></li><li><span style=\"font-size: 14px;\">THEA 80U: Everybody Dance Now!</span></li><li><span style=\"font-size: 14px;\">THEA 80Z: Indian Dance</span></li></ul><p><br></p><p><strong style=\"font-size: 14px;\">The following production fundamentals course:</strong></p><ul><li><span style=\"font-size: 14px;\">THEA 50: Fundamentals of Theater Production</span></li></ul><p><br></p><p><br></p><p><span style=\"font-size: 14px;\">Transfer students may petition to have equivalent lower-division courses taken at other schools count toward lower-division minor requirements and should consult with the Theater Arts academic advisor as early as possible regarding this possibility.</span></p><p><br></p><p><span style=\"font-size: 14px;\">Please visit the </span><a href=\"https://play.ucsc.edu/\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"font-size: 14px;\">Performance, Play &amp; Design website</a><span style=\"font-size: 14px;\"> to learn more about this minor.</span></p><p><a href=\"https://catalog.ucsc.edu/en/current/general-catalog/academic-units/arts-division/performance-play-and-design/dance-minor/\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"font-size: 14px;\">UC Santa Cruz General Catalog: Dance Minor Program Statement</a></p>"
    }
