  "notes": [
    {
      "id": "74756f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 0,
      "content": "GENERAL INFORMATION FOR ALL MINORS",
      "contentHtml": null
    },
    {
      "id": "90c86f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 1,
      "content": "UC Santa Cruz students may complete one or more minors, provided they can finish all required coursework within their maximum enrollment terms and credit limits. Minors are recorded on the official transcript but do not appear on the diploma. Pursuing a minor is optional and should align with a student’s academic interests and career goals. Students do not apply for minors as part of their UC Santa Cruz admission application. Transfer students interested in a minor should reach out to the department that offers it for advising during their first quarter of enrollment.",
      "contentHtml": "<p><span style=\"font-size: 14px;\">UC Santa Cruz students may complete one or more minors, provided they can finish all required coursework within their maximum enrollment terms and credit limits. Minors are recorded on the official transcript but do not appear on the diploma. Pursuing a minor is optional and should align with a student’s academic interests and career goals.</span></p><p><br></p><p><span style=\"font-size: 14px;\">Students do not apply for minors as part of their UC Santa Cruz admission application. Transfer students interested in a minor should reach out to the department that offers it for advising during their first quarter of enrollment.</span></p>"
    },
    {
      "id": "72756f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 2,
      "content": "ELECTRONIC MUSIC MINOR",
      "contentHtml": null
    },
    {
      "id": "71756f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 3,
      "content": "Transfer students interested in this minor are encouraged to complete the articulated equivalents of the courses listed in the \" Preparation for the Minor \" section below prior to transfer. MUSIC THEORY REQUIREMENT Prospective transfer students are encouraged to complete a college-level music theory course before transferring. Students can alternatively satisfy the minor’s theory requirement via the Theory Placement Exam . Visit the Music Department website to learn more about this minor. UC Santa Cruz General Catalog: Electronic Music Minor Program Statement",
      "contentHtml": "<p><span style=\"font-size: 14px;\">Transfer students interested in this minor are encouraged to complete the articulated equivalents of the courses listed in the \"</span><strong style=\"font-size: 14px;\">Preparation for the Minor</strong><span style=\"font-size: 14px;\">\" section below prior to transfer.</span></p><p><br></p><h2><strong>MUSIC THEORY REQUIREMENT</strong></h2><p><span style=\"font-size: 14px;\">Prospective transfer students are encouraged to complete a college-level music theory course before transferring. Students can alternatively satisfy the minor’s theory requirement via the </span><a href=\"https://music.ucsc.edu/academics/theory-placement-exam/\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"font-size: 14px;\"><strong>Theory Placement Exam</strong></a><span style=\"font-size: 14px;\">.</span></p><p><br></p><p><br></p><p><span style=\"font-size: 14px;\">Visit the </span><a href=\"https://music.ucsc.edu/\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"font-size: 14px;\">Music Department website</a><span style=\"font-size: 14px;\"> to learn more about this minor.</span></p><p><a href=\"https://catalog.ucsc.edu/en/current/general-catalog/academic-units/arts-division/music/electronic-music-minor/\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"font-size: 14px;\">UC Santa Cruz General Catalog: Electronic Music Minor Program Statement</a></p>"
    }
  ],
