  "notes": [
    {
      "id": "d1776f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 0,
      "content": "GENERAL INFORMATION FOR ALL MINORS",
      "contentHtml": null
    },
    {
      "id": "90c86f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 1,
      "content": "UC Santa Cruz students may complete one or more minors, provided they can finish all required coursework within their maximum enrollment terms and credit limits. Minors are recorded on the official transcript but do not appear on the diploma. Pursuing a minor is optional and should align with a student’s academic interests and career goals. Students do not apply for minors as part of their UC Santa Cruz admission application. Transfer students interested in a minor should reach out to the department that offers it for advising during their first quarter of enrollment.",
      "contentHtml": "<p><span style=\"font-size: 14px;\">UC Santa Cruz students may complete one or more minors, provided they can finish all required coursework within their maximum enrollment terms and credit limits. Minors are recorded on the official transcript but do not appear on the diploma. Pursuing a minor is optional and should align with a student’s academic interests and career goals.</span></p><p><br></p><p><span style=\"font-size: 14px;\">Students do not apply for minors as part of their UC Santa Cruz admission application. Transfer students interested in a minor should reach out to the department that offers it for advising during their first quarter of enrollment.</span></p>"
    },
    {
      "id": "d0776f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 2,
      "content": "Italian Studies Minor",
      "contentHtml": null
    },
    {
      "id": "d3776f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 3,
      "content": "Students interested in an interdisciplinary approach to Italian culture through the combined study of language, literature, history, and art history may pursue a minor in Italian studies. The Italian studies minor requires the equivalent of two years of college-level Italian language training. Prospective transfer students interested in this minor are strongly recommended to complete at least the first year of Italian language training before transferring. Please visit the Italian Studies website to learn more about this minor. UC Santa Cruz General Catalog: Italian Studies Minor Program Statement",
      "contentHtml": "<p><span style=\"font-size: 14px;\">Students interested in an interdisciplinary approach to Italian culture through the combined study of language, literature, history, and art history may pursue a minor in Italian studies.</span></p><p><br></p><p><span style=\"font-size: 14px;\">The Italian studies minor requires the equivalent of two years of college-level Italian language training. Prospective transfer students interested in this minor are strongly recommended to complete at least the first year of Italian language training before transferring.</span></p><p><br></p><p><br></p><p><span style=\"font-size: 14px;\">Please visit the </span><a href=\"https://italianstudies.ucsc.edu/academics/index.html\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"font-size: 14px;\">Italian Studies website</a><span style=\"font-size: 14px;\"> to learn more about this minor.</span></p><p><a href=\"https://catalog.ucsc.edu/en/current/general-catalog/academic-units/humanities-division/literature/italian-studies-minor/\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"font-size: 14px;\">UC Santa Cruz General Catalog: Italian Studies Minor Program Statement</a></p>"
    }
  ],
