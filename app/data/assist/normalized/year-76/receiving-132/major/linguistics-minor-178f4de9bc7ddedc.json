    {
      "id": "a5746f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 3,
      "content": "PREPARATION FOR THE MINOR LING 50: Introduction to Linguistics LING 53: Semantics I Please visit the Linguistics website to learn more about this minor. UC Santa Cruz General Catalog: Linguistics Minor Program Statement",
      "contentHtml": "<h2><strong>PREPARATION FOR THE MINOR</strong></h2><p><br></p><ul><li><span style=\"font-size: 14px;\">LING 50: Introduction to Linguistics</span></li><li><span style=\"font-size: 14px;\">LING 53: Semantics I</span></li></ul><p><br></p><p><span style=\"font-size: 14px;\">Please visit the </span><a href=\"https://linguistics.ucsc.edu/undergraduate-programs/linguistics-major-minor/\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"font-size: 14px;\">Linguistics website</a><span style=\"font-size: 14px;\"> to learn more about this minor.</span></p><p><a href=\"https://catalog.ucsc.edu/en/current/general-catalog/academic-units/humanities-division/linguistics/linguistics-minor/\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"font-size: 14px;\">UC Santa Cruz General Catalog: Linguistics Minor Program Statement</a></p>"
