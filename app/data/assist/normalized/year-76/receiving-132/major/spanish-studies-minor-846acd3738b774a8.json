  "notes": [
    {
      "id": "ee756f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 0,
      "content": "GENERAL INFORMATION FOR ALL MINORS",
      "contentHtml": null
    },
    {
      "id": "90c86f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 1,
      "content": "UC Santa Cruz students may complete one or more minors, provided they can finish all required coursework within their maximum enrollment terms and credit limits. Minors are recorded on the official transcript but do not appear on the diploma. Pursuing a minor is optional and should align with a student’s academic interests and career goals. Students do not apply for minors as part of their UC Santa Cruz admission application. Transfer students interested in a minor should reach out to the department that offers it for advising during their first quarter of enrollment.",
      "contentHtml": "<p><span style=\"font-size: 14px;\">UC Santa Cruz students may complete one or more minors, provided they can finish all required coursework within their maximum enrollment terms and credit limits. Minors are recorded on the official transcript but do not appear on the diploma. Pursuing a minor is optional and should align with a student’s academic interests and career goals.</span></p><p><br></p><p><span style=\"font-size: 14px;\">Students do not apply for minors as part of their UC Santa Cruz admission application. Transfer students interested in a minor should reach out to the department that offers it for advising during their first quarter of enrollment.</span></p>"
    },
    {
      "id": "ec756f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 2,
      "content": "Spanish Studies Minor",
      "contentHtml": null
    },
    {
      "id": "e8756f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 3,
      "content": "PREPARATION FOR THE MINOR Six quarters of Spanish language study, or demonstration of an equivalent level of ability, and the following course: LING 50: Introduction to Linguistics Please visit the Languages and Applied Linguistics website to learn more about this minor. UC Santa Cruz General Catalog: Spanish Studies Minor Program Statement",
      "contentHtml": "<h2><strong>PREPARATION FOR THE MINOR</strong></h2><p><br></p><p><span style=\"font-size: 14px;\">Six quarters of Spanish language study, or demonstration of an equivalent level of ability, and the following course:</span></p><p><br></p><p class=\"ql-indent-1\"><strong style=\"font-size: 14px;\">LING 50: Introduction to Linguistics</strong></p><p><br></p><p><br></p><p><span style=\"font-size: 14px;\">Please visit the </span><a href=\"https://language.ucsc.edu/\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"font-size: 14px;\">Languages and Applied Linguistics website</a><span style=\"font-size: 14px;\"> to learn more about this minor.</span></p><p><a href=\"https://catalog.ucsc.edu/en/current/general-catalog/academic-units/humanities-division/languages-and-applied-linguistics/spanish-studies-minor/\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"font-size: 14px;\">UC Santa Cruz General Catalog: Spanish Studies Minor Program Statement</a></p>"
    }
  ],
