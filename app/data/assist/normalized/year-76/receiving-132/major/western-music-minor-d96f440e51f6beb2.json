  "notes": [
    {
      "id": "17766f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 0,
      "content": "GENERAL INFORMATION FOR ALL MINORS",
      "contentHtml": null
    },
    {
      "id": "90c86f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 1,
      "content": "UC Santa Cruz students may complete one or more minors, provided they can finish all required coursework within their maximum enrollment terms and credit limits. Minors are recorded on the official transcript but do not appear on the diploma. Pursuing a minor is optional and should align with a student’s academic interests and career goals. Students do not apply for minors as part of their UC Santa Cruz admission application. Transfer students interested in a minor should reach out to the department that offers it for advising during their first quarter of enrollment.",
      "contentHtml": "<p><span style=\"font-size: 14px;\">UC Santa Cruz students may complete one or more minors, provided they can finish all required coursework within their maximum enrollment terms and credit limits. Minors are recorded on the official transcript but do not appear on the diploma. Pursuing a minor is optional and should align with a student’s academic interests and career goals.</span></p><p><br></p><p><span style=\"font-size: 14px;\">Students do not apply for minors as part of their UC Santa Cruz admission application. Transfer students interested in a minor should reach out to the department that offers it for advising during their first quarter of enrollment.</span></p>"
    },
    {
      "id": "1f766f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 2,
      "content": "Western Music Minor",
      "contentHtml": null
    },
    {
      "id": "19766f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 3,
      "content": "Transfer students interested in this minor are encouraged to complete the articulated equivalents of the courses listed in the \" Preparation for the Minor \" section below prior to transfer. Theory Preparation The Music Department encourages transfer students to take the Theory Placement Exam and seek academic counseling before starting classes at UC Santa Cruz. Performance Preparation Students are encouraged to begin performing ensembles and applied lessons on a specific instrument or voice before transfer. Upon transfer, community college ensemble and lesson participation can be petitioned to count toward the minor requirements. Visit the Music Department website to learn more about this minor. UC Santa Cruz General Catalog: Western Music Minor Program Statement",
      "contentHtml": "<p><span style=\"font-size: 14px;\">Transfer students interested in this minor are encouraged to complete the articulated equivalents of the courses listed in the \"</span><strong style=\"font-size: 14px;\">Preparation for the Minor</strong><span style=\"font-size: 14px;\">\" section below prior to transfer.</span></p><p><br></p><p><strong style=\"font-size: 16px;\"><u>Theory Preparation</u></strong></p><p><span style=\"font-size: 14px;\">The Music Department encourages transfer students to take the </span><a href=\"https://music.ucsc.edu/academics/theory-placement-exam/\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"font-size: 14px;\"><strong>Theory Placement Exam</strong></a><span style=\"font-size: 14px;\"> and seek academic counseling before starting classes at UC Santa Cruz.</span></p><p><br></p><p><strong style=\"font-size: 16px;\"><u>Performance Preparation</u></strong></p><p><span style=\"font-size: 14px;\">Students are encouraged to begin performing ensembles and applied lessons on a specific instrument or voice before transfer. Upon transfer, community college ensemble and lesson participation can be petitioned to count toward the minor requirements. </span></p><p><br></p><p><span style=\"font-size: 14px;\">Visit the </span><a href=\"https://music.ucsc.edu/\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"font-size: 14px;\">Music Department website</a><span style=\"font-size: 14px;\"> to learn more about this minor.</span></p><p><a href=\"https://catalog.ucsc.edu/en/current/general-catalog/academic-units/arts-division/music/western-music-minor\" rel=\"noopener noreferrer\" target=\"_blank\" style=\"font-size: 14px;\">UC Santa Cruz General Catalog: Western Music Minor Program Statement</a></p>"
    }
