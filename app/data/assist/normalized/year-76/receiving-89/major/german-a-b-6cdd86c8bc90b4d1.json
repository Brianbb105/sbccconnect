  "notes": [
    {
      "id": "bd8e6f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 0,
      "content": "THE MAJOR PROGRAM",
      "contentHtml": null
    },
    {
      "id": "b78e6f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 1,
      "content": "The German major explores in depth the literature and language, the culture, history, politics, and commerce of the German-speaking world (primarily Germany, Austria and Switzerland). The key to the major lies in the careful balance between solid core requirements and the possibility to explore German subject areas through the lens of other disciplines, such as music, art, philosophy, history, and economics. The department offers courses that highlight literary figures, movements and themes. These courses form the core of upper division literature electives, but we also offer courses that discuss contemporary culture, history, politics, and commerce in German-speaking countries. Regardless of emphasis, students will find maximum practice in spoken and written German as well as in listening comprehension in all upper division courses offered in German.",
      "contentHtml": "<p>The <a href=\"https://local-resources.ucdavis.edu/local_resources/docs/catalog/GenCat20252026.pdf\" rel=\"noopener noreferrer\" target=\"_blank\">German</a> major explores in depth the literature and language, the culture, history, politics, and commerce of the German-speaking world (primarily Germany, Austria and Switzerland). The key to the major lies in the careful balance between solid core requirements and the possibility to explore German subject areas through the lens of other disciplines, such as music, art, philosophy, history, and economics.</p><p><br></p><p>The department offers courses that highlight literary figures, movements and themes. These courses form the core of upper division literature electives, but we also offer courses that discuss contemporary culture, history, politics, and commerce in German-speaking countries. Regardless of emphasis, students will find maximum practice in spoken and written German as well as in listening comprehension in all upper division courses offered in German.</p>"
    },
    {
      "id": "c18e6f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 2,
      "content": "CAREER ALTERNATIVES",
      "contentHtml": null
    },
    {
      "id": "bb8e6f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 3,
      "content": "Completion of the major prepares students for graduate study in German or for career opportunities in international fields ranging from employment in business and government to careers in the fine arts and sciences. Also, it permits admission to professional schools such as law and medicine.",
      "contentHtml": "<p>Completion of the major prepares students for graduate study in German or for career opportunities in international fields ranging from employment in business and government to careers in the fine arts and sciences. Also, it permits admission to professional schools such as law and medicine.</p>"
    },
    {
      "id": "bf8e6f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 4,
      "content": "ADMISSIONS INFORMATION",
      "contentHtml": null
    },
    {
      "id": "db8e6f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 5,
      "content": "This major is not currently screening for major preparation at the time of admission; however, it is strongly encouraged that you complete as many major preparation courses as possible prior to transfer. Incomplete foundational coursework may delay your ability to graduate on time. Visit Department agreements as needed Contact your UC Davis Advisor for questions ( Find my advisor ) Note: Advanced Placement (AP) and International Baccalaureate (IB) Examination: AP and IB examination credit policies are detailed in the UC Davis General Catalog . Quick reference charts for AP and IB .",
      "contentHtml": "<p>This major is not currently screening for major preparation at the time of admission; however, it is strongly encouraged that you complete as many major preparation courses as possible prior to transfer. Incomplete foundational coursework may delay your ability to graduate on time.</p><p>&nbsp;</p><p>Visit Department agreements as needed</p><p><br></p><p>Contact your UC Davis Advisor for questions (<a href=\"https://ua.ucdavis.edu/portal/find-my-advisor\" rel=\"noopener noreferrer\" target=\"_blank\">Find my advisor</a>)</p><p><br></p><p>Note:</p><p><strong>Advanced Placement (AP) and International Baccalaureate (IB) Examination:</strong></p><p>AP and IB examination credit policies are detailed in the UC Davis <a href=\"https://local-resources.ucdavis.edu/local_resources/docs/catalog/GenCat20252026.pdf\" rel=\"noopener noreferrer\" target=\"_blank\">General Catalog</a>. Quick reference charts for <a href=\"https://local-resources.ucdavis.edu/local_resources/docs/APIBCharts/APCurrent.pdf\" rel=\"noopener noreferrer\" target=\"_blank\">AP</a> and <a href=\"https://local-resources.ucdavis.edu/local_resources/docs/APIBCharts/IBCurrent.pdf\" rel=\"noopener noreferrer\" target=\"_blank\">IB</a>.</p>"
    },
    {
      "id": "a68e6f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 6,
      "content": "TRANSFER ADMISSIONS GUARANTEE (TAG)",
      "contentHtml": null
    },
    {
      "id": "c58e6f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 7,
      "content": "At the time of TAG submission, this major requires a minimum 3.20 cumulative GPA, with no grade lower than a C to receive a Transfer Admission Guarantee.",
      "contentHtml": "<p>At the time of TAG submission, this major requires a minimum 3.20 cumulative GPA, with no grade lower than a C to receive a Transfer Admission Guarantee.</p>"
    },
    {
      "id": "fe1696de-4b15-4f4f-ae09-019b19eb7d8f",
      "type": "GeneralTitle",
      "area": "General",
      "position": 8,
      "content": "German Placement Examination",
      "contentHtml": null
    },
    {
      "id": "2e303e88-88aa-4186-bfdd-019b14860832",
      "type": "GeneralText",
      "area": "General",
      "position": 9,
      "content": "German Placement Examination Note: Course placement for German language courses is strictly by proficiency exam. See information related to German proficiency exams and also information regarding foreign language proficiency exams. For more information, contact the German department academic advisor or visit the German Placement Exam website.",
      "contentHtml": "<p><strong>German Placement Examination Note:</strong></p><p>&nbsp;</p><p>Course placement for German language courses is strictly by proficiency exam. See information related to German proficiency exams and also information regarding foreign language proficiency exams. For more information, contact the German department academic advisor or visit the <a href=\"https://ucdlc.ucdavis.edu/foreign-language-placement-exams\" rel=\"noopener noreferrer\" target=\"_blank\">German Placement Exam</a> website.</p>"
    }
