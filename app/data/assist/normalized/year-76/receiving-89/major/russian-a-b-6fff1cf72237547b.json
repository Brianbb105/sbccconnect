  "notes": [
    {
      "id": "83567445-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 0,
      "content": "THE MAJOR PROGRAM",
      "contentHtml": null
    },
    {
      "id": "80567445-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 1,
      "content": "The Russian major introduces students to a culture rich in art, music, theater, film, language, and literature. The major offers an opportunity to learn skills needed to enter the fields of foreign affairs, world politics, and international trade, or to begin graduate work in literature, history, cultural studies and international relations. The major program instructs students in speaking, understanding, reading, and writing the Russian language. The program also acquaints students with the intellectual and cultural contributions of the Russian world through the study of its literature, traditions, and institutions.",
      "contentHtml": "<p>The <a href=\"https://local-resources.ucdavis.edu/local_resources/docs/catalog/GenCat20252026.pdf\" rel=\"noopener noreferrer\" target=\"_blank\">Russian</a> major introduces students to a culture rich in art, music, theater, film, language, and literature. The major offers an opportunity to learn skills needed to enter the fields of foreign affairs, world politics, and international trade, or to begin graduate work in literature, history, cultural studies and international relations.</p><p><br></p><p>The major program instructs students in speaking, understanding, reading, and writing the Russian language. The program also acquaints students with the intellectual and cultural contributions of the Russian world through the study of its literature, traditions, and institutions.</p>"
    },
    {
      "id": "85567445-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 2,
      "content": "CAREER ALTERNATIVES",
      "contentHtml": null
    },
    {
      "id": "7c567445-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 3,
      "content": "Russian majors may participate in internships where they can serve as translators and interpreters for schools and business firms throughout Northern California. Upon graduation, many Russian majors enter the business world or enter graduate programs in Slavic studies and international relations. The program encourages students to supplement their Russian studies with courses in related fields such as international relations, political science, computer science, cultural studies, or economics in order to maximize their career possibilities.",
      "contentHtml": "<p>Russian majors may participate in internships where they can serve as translators and interpreters for schools and business firms throughout Northern California. Upon graduation, many Russian majors enter the business world or enter graduate programs in Slavic studies and international relations. The program encourages students to supplement their Russian studies with courses in related fields such as international relations, political science, computer science, cultural studies, or economics in order to maximize their career possibilities.</p>"
    },
    {
      "id": "7a567445-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 4,
      "content": "ADMISSIONS INFORMATION",
      "contentHtml": null
    },
    {
      "id": "96567445-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 5,
      "content": "This major is not currently screening for major preparation at the time of admission; however, it is strongly encouraged that you complete as many major preparation courses as possible prior to transfer. Incomplete foundational coursework may delay your ability to graduate on time. Visit Department agreements as needed Contact your UC Davis Advisor for questions ( Find my advisor ) Note: Advanced Placement (AP) and International Baccalaureate (IB) Examination: AP and IB examination credit policies are detailed in the UC Davis General Catalog . Quick reference charts for AP and IB .",
      "contentHtml": "<p>This major is not currently screening for major preparation at the time of admission; however, it is strongly encouraged that you complete as many major preparation courses as possible prior to transfer. Incomplete foundational coursework may delay your ability to graduate on time.</p><p>&nbsp;</p><p>Visit Department agreements as needed</p><p><br></p><p>Contact your UC Davis Advisor for questions (<a href=\"https://ua.ucdavis.edu/portal/find-my-advisor\" rel=\"noopener noreferrer\" target=\"_blank\">Find my advisor</a>)</p><p><br></p><p>Note:</p><p><strong>Advanced Placement (AP) and International Baccalaureate (IB) Examination:</strong></p><p>AP and IB examination credit policies are detailed in the UC Davis <a href=\"https://local-resources.ucdavis.edu/local_resources/docs/catalog/GenCat20252026.pdf\" rel=\"noopener noreferrer\" target=\"_blank\">General Catalog</a>. Quick reference charts for <a href=\"https://local-resources.ucdavis.edu/local_resources/docs/APIBCharts/APCurrent.pdf\" rel=\"noopener noreferrer\" target=\"_blank\">AP</a> and <a href=\"https://local-resources.ucdavis.edu/local_resources/docs/APIBCharts/IBCurrent.pdf\" rel=\"noopener noreferrer\" target=\"_blank\">IB</a>.</p>"
    },
    {
      "id": "72567445-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 6,
      "content": "TRANSFER ADMISSIONS GUARANTEE (TAG)",
      "contentHtml": null
    },
    {
      "id": "89567445-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 7,
      "content": "At the time of TAG submission, this major requires a minimum 3.20 cumulative GPA, with no grade lower than a C to receive a Transfer Admission Guarantee.",
      "contentHtml": "<p>At the time of TAG submission, this major requires a minimum 3.20 cumulative GPA, with no grade lower than a C to receive a Transfer Admission Guarantee.</p>"
    }
