  "notes": [
    {
      "id": "37b16f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 0,
      "content": "THE MAJOR PROGRAM",
      "contentHtml": null
    },
    {
      "id": "38b16f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 1,
      "content": "The A.B. degree in Theatre &amp; Dance provides students with an appreciation for an understanding of performance and its role in culture and society. Students build skills in specific areas as well as a broad knowledge of theatre and dance. Each year's schedule includes opportunities to work with professional artists (directors, choreographers and writers) in Granada Artists-in Residence productions, faculty and student-led workshops and productions, and the Film Festival at UC Davis. These productions are staged in our proscenium (Main), thrust (Wyatt), black box (Arena), performance studio (Della Davidson Performance Studio) and intimate laboratory theatre (Lab A). These productions are part of the academic program of the department and serve an important purpose in the study of theatre and dance. Participation is open to all students. All students completing a major in Theatre &amp; Dance must participate in productions, including work in at least two of the following three areas: performance (acting/dance), design, and directing/playwriting/stage management, as well as crew assignments and work in production labs.",
      "contentHtml": "<p>The A.B. degree in <a href=\"https://local-resources.ucdavis.edu/local_resources/docs/catalog/GenCat20252026.pdf\" rel=\"noopener noreferrer\" target=\"_blank\">Theatre &amp; Dance</a> provides students with an appreciation for an understanding of performance and its role in culture and society. Students build skills in specific areas as well as a broad knowledge of theatre and dance.</p><p><br></p><p>Each year's schedule includes opportunities to work with professional artists (directors, choreographers and writers) in Granada Artists-in Residence productions, faculty and student-led workshops and productions, and the Film Festival at UC Davis. These productions are staged in our proscenium (Main), thrust (Wyatt), black box (Arena), performance studio (Della Davidson Performance Studio) and intimate laboratory theatre (Lab A). These productions are part of the academic program of the department and serve an important purpose in the study of theatre and dance. Participation is open to all students.</p><p><br></p><p>All students completing a major in Theatre &amp; Dance must participate in productions, including work in at least two of the following three areas: performance (acting/dance), design, and directing/playwriting/stage management, as well as crew assignments and work in production labs.</p>"
    },
    {
      "id": "39b16f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 2,
      "content": "ADMISSIONS INFORMATION",
      "contentHtml": null
    },
    {
      "id": "56b16f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 3,
      "content": "This major is not currently screening for major preparation at the time of admission; however, it is strongly encouraged that you complete as many major preparation courses as possible prior to transfer. Incomplete foundational coursework may delay your ability to graduate on time. Visit Department agreements as needed Contact your UC Davis Advisor for questions ( Find my advisor ) Note: Advanced Placement (AP) and International Baccalaureate (IB) Examination: AP and IB examination credit policies are detailed in the UC Davis General Catalog . Quick reference charts for AP and IB .",
      "contentHtml": "<p>This major is not currently screening for major preparation at the time of admission; however, it is strongly encouraged that you complete as many major preparation courses as possible prior to transfer. Incomplete foundational coursework may delay your ability to graduate on time.</p><p>&nbsp;</p><p>Visit Department agreements as needed</p><p><br></p><p>Contact your UC Davis Advisor for questions (<a href=\"https://ua.ucdavis.edu/portal/find-my-advisor\" rel=\"noopener noreferrer\" target=\"_blank\">Find my advisor</a>)</p><p><br></p><p>Note:</p><p><strong>Advanced Placement (AP) and International Baccalaureate (IB) Examination:</strong></p><p>AP and IB examination credit policies are detailed in the UC Davis <a href=\"https://local-resources.ucdavis.edu/local_resources/docs/catalog/GenCat20252026.pdf\" rel=\"noopener noreferrer\" target=\"_blank\">General Catalog</a>. Quick reference charts for <a href=\"https://local-resources.ucdavis.edu/local_resources/docs/APIBCharts/APCurrent.pdf\" rel=\"noopener noreferrer\" target=\"_blank\">AP</a> and <a href=\"https://local-resources.ucdavis.edu/local_resources/docs/APIBCharts/IBCurrent.pdf\" rel=\"noopener noreferrer\" target=\"_blank\">IB</a>.</p>"
    },
    {
      "id": "2bb16f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralTitle",
      "area": "General",
      "position": 4,
      "content": "TRANSFER ADMISSIONS GUARANTEE (TAG)",
      "contentHtml": null
    },
    {
      "id": "54b16f45-6887-ef11-8474-000d3a37e3b6",
      "type": "GeneralText",
      "area": "General",
      "position": 5,
      "content": "At the time of TAG submission, this major requires a minimum 3.20 cumulative GPA, with no grade lower than a C to receive a Transfer Admission Guarantee.",
      "contentHtml": "<p>At the time of TAG submission, this major requires a minimum 3.20 cumulative GPA, with no grade lower than a C to receive a Transfer Admission Guarantee.</p>"
    }
